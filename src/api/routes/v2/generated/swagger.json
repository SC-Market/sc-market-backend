	"paths": {
		"/variant-types": {
			"get": {
				"operationId": "GetAllVariantTypes",
				"responses": {
					"200": {
						"description": "List of variant types with validation rules",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/VariantTypesResponse"
								}
							}
						}
					}
				},
				"description": "Get all variant types\n\nReturns a list of all available variant types with their validation rules.\nVariant types define the attributes that can be used when creating item variants,\nincluding quality_tier, quality_value, crafted_source, and blueprint_tier.\n\nResults are ordered by display_order for consistent UI presentation.",
				"summary": "List all variant types",
				"tags": [
					"Variant Types V2"
				],
				"security": [],
				"parameters": []
			}
		},
		"/variant-types/{variant_type_id}": {
			"get": {
				"operationId": "GetVariantTypeById",
				"responses": {
					"200": {
						"description": "Variant type details",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/VariantTypeResponse"
								}
							}
						}
					}
				},
				"description": "Get variant type by ID\n\nReturns detailed information about a specific variant type including\nvalidation rules (min_value, max_value, allowed_values) and display configuration.",
				"summary": "Get variant type details",
				"tags": [
					"Variant Types V2"
				],
				"security": [],
				"parameters": [
					{
						"description": "Variant type ID to retrieve",
						"in": "path",
						"name": "variant_type_id",
						"required": true,
						"schema": {
							"type": "string"
						}
					}
				]
			}
		},
		"/listings/search": {
			"get": {
				"operationId": "SearchListings",
				"responses": {
					"200": {
						"description": "Search results with pagination metadata",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/SearchListingsResponse"
								}
							}
						}
					}
				},
				"description": "Search listings with filters\n\nSearches active listings using full-text search, quality tier filters, price filters,\nand game item filters. Results are paginated and include price/quality ranges.",
				"summary": "Search market listings",
				"tags": [
					"Listings V2"
				],
				"security": [],
				"parameters": [
					{
						"description": "Optional full-text search query",
						"in": "query",
						"name": "text",
						"required": false,
						"schema": {
							"type": "string"
						}
					},
					{
						"description": "Optional game item ID filter",
						"in": "query",
						"name": "game_item_id",
						"required": false,
						"schema": {
							"type": "string"
						}
					},
					{
						"description": "Optional minimum quality tier (1-5)",
						"in": "query",
						"name": "quality_tier_min",
						"required": false,
						"schema": {
							"format": "double",
							"type": "number"
						}
					},
					{
						"description": "Optional maximum quality tier (1-5)",
						"in": "query",
						"name": "quality_tier_max",
						"required": false,
						"schema": {
							"format": "double",
							"type": "number"
						}
					},
					{
						"description": "Optional minimum price filter",
						"in": "query",
						"name": "price_min",
						"required": false,
						"schema": {
							"format": "double",
							"type": "number"
						}
					},
					{
						"description": "Optional maximum price filter",
						"in": "query",
						"name": "price_max",
						"required": false,
						"schema": {
							"format": "double",
							"type": "number"
						}
					},
					{
						"description": "Page number (default: 1)",
						"in": "query",
						"name": "page",
						"required": false,
						"schema": {
							"default": 1,
							"format": "double",
							"type": "number"
						}
					},
					{
						"description": "Results per page (default: 20, max: 100)",
						"in": "query",
						"name": "page_size",
						"required": false,
						"schema": {
							"default": 20,
							"format": "double",
							"type": "number"
						}
					}
				]
			}
		},
		"/listings": {
			"post": {
				"operationId": "CreateListing",
				"responses": {
					"200": {
						"description": "Created listing object",
						"content": {
