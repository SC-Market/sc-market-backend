	"paths": {
		"/listings": {
			"post": {
				"operationId": "CreateListing",
				"responses": {
					"200": {
						"description": "Created listing with listing_id",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/CreateListingResponse"
								}
							}
						}
					}
				},
				"description": "Create a new listing with variants\n\nCreates a listing with stock lots that have variant attributes (quality tier, crafted source, etc).\nUses database transaction for atomicity. Supports unified pricing (one price for all variants)\nor per-variant pricing (different prices per quality tier).\n\nThe variant deduplication logic ensures that variants with identical attributes are reused\nacross listings, preventing duplicate variant records.\n\nRequirements:\n- 14.1: POST /api/v2/listings endpoint\n- 14.2: Accept title, description, game_item_id\n- 14.3: Accept pricing_mode and base_price\n- 14.4: Accept array of lots with variant_attributes\n- 14.5: Create or reuse variants based on variant_attributes\n- 14.6: Create stock_lots for each lot\n- 14.7: Use database transaction for atomicity\n- 14.8: Validate all inputs before creating listing\n- 14.9: Return created listing with listing_id\n- 14.11: Validate seller ownership before creation",
				"summary": "Create listing",
				"tags": [
					"Listings V2"
				],
				"security": [],
				"parameters": [],
				"requestBody": {
					"description": "Listing creation request with title, description, pricing, and lots",
					"required": true,
					"content": {
						"application/json": {
							"schema": {
								"$ref": "#/components/schemas/CreateListingRequest",
								"description": "Listing creation request with title, description, pricing, and lots"
							}
						}
					}
				}
			}
		},
		"/listings/{id}": {
			"get": {
				"operationId": "GetListingDetail",
				"responses": {
					"200": {
						"description": "Complete listing detail with variant breakdown",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/GetListingDetailResponse"
								}
							}
						}
					}
				},
				"description": "Get listing detail with variant breakdown\n\nRetrieves complete listing information including seller details, game item information,\nand variant breakdown with quantities, prices, and locations. Returns 404 if listing\nnot found.\n\nRequirements:\n- 16.1: GET /api/v2/listings/:id endpoint\n- 16.2: Return listing metadata with seller information\n- 16.3: Return array of items with game_item details\n- 16.4: Return array of variants for each item with attributes\n- 16.5: Return quantity and price for each variant\n- 16.6: Return display_name for each variant\n- 16.7: Include location information for stock lots\n- 16.8: Include crafted_by information if applicable\n- 16.9: Return 404 if listing not found\n- 16.10: Include view count and timestamps\n- 16.11: Include seller rating and status\n- 16.12: Support image gallery with multiple photos",
				"summary": "Get listing detail",
				"tags": [
					"Listings V2"
				],
				"security": [],
				"parameters": [
					{
						"description": "Listing UUID",
						"in": "path",
						"name": "id",
						"required": true,
						"schema": {
							"type": "string"
						}
					}
				]
			},
			"put": {
				"operationId": "UpdateListing",
				"responses": {
					"200": {
						"description": "Updated listing with variant breakdown",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/GetListingDetailResponse"
								}
							}
						}
					}
				},
				"description": "Update an existing listing\n\nUpdates listing metadata (title, description), pricing (base_price or per-variant prices),\nand stock lot details (quantities, listed status, locations). Validates ownership before\nallowing updates and prevents editing sold or cancelled listings.\n\nRequirements:\n- 17.1: PUT /api/v2/listings/:id endpoint\n- 17.2: Allow updating title and description\n- 17.3: Allow updating base_price for unified pricing mode\n- 17.4: Allow updating per-variant prices for per_variant pricing mode\n- 17.5: Allow updating stock lot quantities\n- 17.6: Allow updating stock lot listed status\n- 17.7: Prevent editing sold or cancelled listings\n- 17.8: Validate ownership before allowing updates\n- 17.9: Return updated listing with variant breakdown\n- 17.10: Log all modifications to Audit_Trail\n- 17.11: Use database transaction for atomicity\n- 17.12: Invalidate cache after updates",
				"summary": "Update listing",
				"tags": [
					"Listings V2"
				],
				"security": [],
				"parameters": [
					{
						"description": "Listing UUID",
						"in": "path",
						"name": "id",
						"required": true,
						"schema": {
							"type": "string"
						}
					}
				],
				"requestBody": {
					"description": "Update request with optional fields",
					"required": true,
					"content": {
						"application/json": {
							"schema": {
								"$ref": "#/components/schemas/UpdateListingRequest",
								"description": "Update request with optional fields"
							}
						}
					}
				}
			}
		},
		"/listings/search": {
			"get": {
				"operationId": "SearchListings",
				"responses": {
					"200": {
						"description": "Search results with pagination metadata",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/SearchListingsResponse"
								}
							}
						}
					}
				},
				"description": "Search listings with filters\n\nSearches active listings using full-text search, quality tier filters, price filters,\nand game item filters. Uses the listing_search view for optimized query performance.\n\nRequirements:\n- 15.1: GET /api/v2/listings/search endpoint\n- 15.2: Accept text query parameter for full-text search\n- 15.3: Accept game_item_id parameter for item filtering\n- 15.4: Accept quality_tier_min and quality_tier_max parameters\n- 15.5: Accept price_min and price_max parameters\n- 15.6: Accept page and page_size parameters for pagination\n- 15.7: Return listings with price_min, price_max, quality_tier_min, quality_tier_max\n- 15.8: Return total count for pagination\n- 15.9: Support sorting by created_at, price, quality, seller_rating\n- 15.10: Include seller information in results\n- 15.11: Include variant_count in results\n- 15.12: Execute queries within 50ms performance target",
				"summary": "Search listings",
				"tags": [
					"Listings V2"
				],
				"security": [],
				"parameters": [
					{
						"description": "Full-text search query",
						"in": "query",
						"name": "text",
						"required": false,
						"schema": {
							"type": "string"
						}
					},
					{
						"description": "Filter by specific game item UUID",
						"in": "query",
						"name": "game_item_id",
						"required": false,
						"schema": {
							"type": "string"
						}
					},
					{
						"description": "Minimum quality tier (1-5)",
						"in": "query",
						"name": "quality_tier_min",
						"required": false,
						"schema": {
							"format": "double",
							"type": "number"
						}
					},
					{
						"description": "Maximum quality tier (1-5)",
						"in": "query",
						"name": "quality_tier_max",
						"required": false,
						"schema": {
							"format": "double",
							"type": "number"
						}
					},
					{
						"description": "Minimum price filter",
						"in": "query",
						"name": "price_min",
						"required": false,
						"schema": {
							"format": "double",
							"type": "number"
						}
					},
					{
						"description": "Maximum price filter",
						"in": "query",
						"name": "price_max",
						"required": false,
						"schema": {
							"format": "double",
							"type": "number"
						}
					},
					{
						"description": "Page number for pagination (default: 1)",
						"in": "query",
						"name": "page",
						"required": false,
						"schema": {
							"format": "double",
							"type": "number"
						}
					},
					{
						"description": "Number of results per page (default: 20, max: 100)",
						"in": "query",
						"name": "page_size",
						"required": false,
						"schema": {
							"format": "double",
							"type": "number"
						}
					},
					{
						"description": "Sort field (default: created_at)",
						"in": "query",
						"name": "sort_by",
						"required": false,
						"schema": {
							"type": "string",
							"enum": [
								"created_at",
								"price",
								"quality",
								"seller_rating"
							]
						}
					},
					{
						"description": "Sort order (default: desc)",
						"in": "query",
						"name": "sort_order",
						"required": false,
						"schema": {
							"type": "string",
							"enum": [
								"asc",
								"desc"
							]
						}
					}
				]
			}
		},
